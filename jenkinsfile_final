pipeline {
    agent any

    // Specify Maven installation configured in Jenkins
    tools {
        maven 'maven3'
    }

    environment {
        GIT_REPO_NAME = "mindcircuit13"
        GIT_USER_NAME = "swathig8660-byte"
    }

    stages {

        stage('Checkout') {
            steps {
                echo 'Cloning GitHub Repo'
                git branch: 'main', url: 'https://github.com/swathig8660-byte/mindcircuit13.git'
            }
        }

        stage('SonarQube Scan') {
            steps {
                echo 'Scanning project with SonarQube'
                sh 'ls -ltr' // optional, for debugging
                sh """
                mvn sonar:sonar \
                  -Dsonar.host.url=http://54.160.212.104:9000 \
                  -Dsonar.login=squ_53db87326cbc7b3ba6782f73fc1fbf2de3073db5
                """
            }
        }

        stage('Build Artifact') {
            steps {
                echo 'Building Maven Artifact'
                sh 'mvn clean package'
            }
        }

        stage('Build Docker Image') {
            steps {
                echo 'Building Docker Image'
                sh "docker build -t swathirani/mindcircuit13:${BUILD_NUMBER} ."
            }
        }

        stage('Push to Docker Hub') {
            steps {
                echo 'Pushing Docker Image to Docker Hub'
                script {
                    // Login to Docker Hub using stored Jenkins credentials
                    withCredentials([string(credentialsId: 'dockerhub', variable: 'dockerhub')]) {
                        sh "echo \"${dockerhub}\" | docker login -u swathirani --password-stdin"
                    }
                    sh "docker push swathirani/mindcircuit13:${BUILD_NUMBER}"
                }
            }
        }

        stage('Update Deployment File') {
            steps {
                echo 'Updating Deployment YAML file with new image tag'
                withCredentials([string(credentialsId: 'githubtoken', variable: 'githubtoken')]) {
                    sh """
                    # Configure git user
                    git config user.email "swathig8660@gmail.com"
                    git config user.name "Madhu"

                    # Update image tag in deployment YAML
                    sed -i "s/mindcircuit13:.*/mindcircuit13:${BUILD_NUMBER}/g" deploymentfiles/deployment.yml

                    # Commit and push changes to GitHub
                    git add .
                    git commit -m "Update deployment image to version ${BUILD_NUMBER}"
                    git push https://${githubtoken}@github.com/${GIT_USER_NAME}/${GIT_REPO_NAME}.git HEAD:main
                    """
                }
            }
        }
    }
}
